# SMTP Configuration for Email Verification
# Required for sending verification codes to users

# SMTP server hostname (e.g., smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=smtp.example.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username
SMTP_USER=support@sqltest.online

# SMTP authentication password
SMTP_PASS=your_smtp_password_here

# OAuth Providers Configuration
# Add your OAuth provider credentials here
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=
# YANDEX_CLIENT_ID=
# YANDEX_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_SECRET=
# VK_ACCESS_TOKEN=

# Donation progress widget settings
# Monthly target amount in USD
# DONATION_MONTHLY_GOAL=50
# Current month's received donations in USD
# DONATION_RECEIVED_CURRENT_MONTH=0

# Urgent banner visibility (set to true to show the banner on all pages)
# SHOW_URGENT_BANNER=false
